{
  "version": 2,
  "builds": [
    {
      "src": "Backend/core/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.11" }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api",
      "destination": "Backend/core/wsgi.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "Backend/core/wsgi.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "Backend/core/wsgi.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "Backend/staticfiles/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "Backend/media/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "frontend/assets/$1"
    },
    {
      "source": "/logo.png",
      "destination": "frontend/logo.png"
    },
    {
      "source": "/manifest.json",
      "destination": "frontend/manifest.json"
    },
    {
      "source": "/favicon.ico",
      "destination": "frontend/favicon.ico"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/index.html"
    }
  ]
}
